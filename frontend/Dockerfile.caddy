FROM node:20-alpine AS build

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./

ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN npm run build

FROM caddy:2-alpine

COPY frontend/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
COPY submission-assets/contest-video-v2/video/ecogenesis-gbif-contest-demo-en-subs.mp4 /srv/submission-video/
COPY submission-assets/contest-video-v2/video/ecogenesis-gbif-contest-demo-en.srt /srv/submission-video/
COPY submission-assets/contest-video-v2/video/ecogenesis-gbif-contest-demo-english-voiceover.txt /srv/submission-video/
COPY submission-assets/contest-video-v2/video/ecogenesis-gbif-contest-demo-transcript.md /srv/submission-video/
COPY submission-assets/contest-video-v2/video/demo-thumbnail-contest-en.png /srv/submission-video/

EXPOSE 80 443
