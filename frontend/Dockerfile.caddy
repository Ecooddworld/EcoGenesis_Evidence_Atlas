FROM node:20-alpine AS build

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./

ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN npm run build

FROM caddy:2-alpine

COPY frontend/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
COPY submission-assets/platform-video/video/ecogenesis-platform-demo-ru-voice-subs.mp4 /srv/submission-video/
COPY submission-assets/platform-video/video/ecogenesis-platform-demo-ru-voice-subs.srt /srv/submission-video/
COPY submission-assets/platform-video/video/ecogenesis-platform-demo-ru-voiceover.txt /srv/submission-video/
COPY submission-assets/platform-video/video/demo-thumbnail-platform-ru.png /srv/submission-video/

EXPOSE 80 443
