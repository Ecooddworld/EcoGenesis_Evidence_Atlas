{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Barcode-to-GBIF Evidence Pack",
  "type": "object",
  "required": ["run", "summary", "reference_manifest", "decision_rules", "metrics", "data_accounting_ledger", "records", "exports"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["run_id", "tool", "ruleset_version", "request_fingerprint"],
      "properties": {
        "run_id": { "type": "string" },
        "tool": { "const": "Barcode-to-GBIF Evidence Compiler" },
        "ruleset_version": { "type": "string" },
        "request_fingerprint": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["title", "project_title", "marker", "reference_database", "processed_records", "verdict"],
      "properties": {
        "title": { "const": "Barcode-to-GBIF Evidence Compiler" },
        "project_title": { "type": "string" },
        "marker": { "type": "string" },
        "reference_database": { "type": "string" },
        "processed_records": { "type": "integer" },
        "verdict": { "type": "string" }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sequence_id", "decision_class", "taxonomic_status", "candidate_taxon", "published_taxon", "publication_stage", "publication_bucket", "export_state", "blockers"],
        "properties": {
          "sequence_id": { "type": "string" },
          "decision_class": {
            "enum": ["species-safe", "genus-safe", "higher-rank-safe", "ambiguous", "weak", "no-match", "not-publishable"]
          },
          "taxonomic_status": { "type": "string" },
          "candidate_taxon": { "type": "object" },
          "published_taxon": { "type": "object" },
          "publication_stage": {
            "enum": ["record_not_ready", "record_min_ready", "record_recommended_ready", "dataset_ready", "gold_ready"]
          },
          "publication_bucket": {
            "enum": ["gbif_ready", "publishable_candidate", "repair_required", "review_only"]
          },
          "export_state": {
            "enum": ["formal_gbif_ready", "dwc_template_ready", "evidence_publishable_repair_required", "review_only", "not_exportable"]
          },
          "safe_taxon": { "type": "object" },
          "blockers": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "data_accounting_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric", "value", "denominator", "unit", "layer", "meaning"],
        "properties": {
          "metric": { "type": "string" },
          "value": {},
          "denominator": {},
          "rate": { "type": ["number", "null"] },
          "unit": { "type": "string" },
          "layer": { "type": "string" },
          "meaning": { "type": "string" }
        }
      }
    }
  }
}
